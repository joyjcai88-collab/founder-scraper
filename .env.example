ANTHROPIC_API_KEY=your-api-key-here

# Optional: Google Custom Search API (free: 100 queries/day)
# If set, Google replaces Brave as the second search engine alongside DuckDuckGo.
# 1. Create a search engine at https://programmablesearchengine.google.com/ (set "Search the entire web" = ON)
# 2. Get an API key at https://console.cloud.google.com/apis/credentials
# 3. Enable "Custom Search API" at https://console.cloud.google.com/apis/library/customsearch.googleapis.com
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Optional: People Data Labs API key for work history, education, and skills enrichment
# Sign up at https://www.peopledatalabs.com/ (free tier: 100 req/min)
PDL_API_KEY=

# Optional: Perplexity AI API key for web research with citations
# Sign up at https://www.perplexity.ai/ and get a key from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Optional: LinkedIn OAuth — free, uses official LinkedIn API (connect your own account)
# No per-request charges. Only returns your own profile data.
# Create an app at https://www.linkedin.com/developers/apps
# Add "Sign In with LinkedIn using OpenID Connect" product
# Set redirect URI to http://localhost:8000/api/linkedin/callback (or your Vercel URL)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/linkedin/callback
